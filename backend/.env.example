# Copy to backend/.env (which is gitignored) and customize.
# Read by `docker compose up` (Compose looks for .env next to docker-compose.yml).

# --- Postgres credentials ---
# The api service builds ConnectionStrings__Default from these.
POSTGRES_DB=agricure
POSTGRES_USER=agricure
POSTGRES_PASSWORD=change-me

# --- Host port mappings (dev override only) ---
# docker-compose.override.yml binds these so Rider / curl can reach the
# services from the host. Ignored when you skip the override file.
POSTGRES_PORT=5432
API_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- MinIO / object storage ---
# Root creds — secrets. STORAGE_ACCESS_KEY/SECRET_KEY are what the API uses
# to talk to MinIO; in single-tenant deployments these usually equal the root creds.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change-me
STORAGE_USE_SSL=false
STORAGE_DEFAULT_BUCKET=agricure-frames

# Public URL the API embeds into picture responses. Browsers fetch images from here.
# Dev: docker-compose.override.yml sets this to http://localhost:9000 automatically.
# Prod: set to your reverse-proxy hostname (e.g. https://media.agricure.online).
STORAGE_PUBLIC_BASE_URL=

# --- JWT signing ---
# Issuer / Audience are arbitrary strings the api both signs and validates against.
# SigningKey MUST be long (32+ chars) and kept out of version control.
JWT_ISSUER=agricure-api
JWT_AUDIENCE=agricure-dashboard
JWT_SIGNING_KEY=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# --- Admin user seed ---
# If both are set, an admin user is created on startup (idempotent).
# Leave blank to skip the seed (e.g. CI environments that bring their own).
ADMIN_EMAIL=admin@agricure.local
ADMIN_PASSWORD=Admin1!ChangeMe

# --- CORS allowlist (production only) ---
# In Development, http://localhost:5173 (Vite) is already whitelisted via
# appsettings.Development.json — no env vars needed for `docker compose up`.
# For prod, list each frontend origin (scheme + host + port, no trailing slash).
# Add more by setting CORS_ALLOWED_ORIGIN_2, _3, ... and exposing them in
# docker-compose.yml the same way.
CORS_ALLOWED_ORIGIN_0=
CORS_ALLOWED_ORIGIN_1=
